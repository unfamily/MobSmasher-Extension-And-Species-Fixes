{
  "multipart": [
    {
      "when": { "on": true, "facing": "north" },
      "apply": { "model": "mobsmash_ext_species_fix:block/soul_inhibitor_on" }
    },
    {
      "when": { "on": true, "facing": "east" },
      "apply": { "model": "mobsmash_ext_species_fix:block/soul_inhibitor_on", "y": 90 }
    },
    {
      "when": { "on": true, "facing": "south" },
      "apply": { "model": "mobsmash_ext_species_fix:block/soul_inhibitor_on", "y": 180 }
    },
    {
      "when": { "on": true, "facing": "west" },
      "apply": { "model": "mobsmash_ext_species_fix:block/soul_inhibitor_on", "y": 270 }
    },
    {
      "when": { "on": false, "facing": "north" },
      "apply": { "model": "mobsmash_ext_species_fix:block/soul_inhibitor_off" }
    },
    {
      "when": { "on": false, "facing": "east" },
      "apply": { "model": "mobsmash_ext_species_fix:block/soul_inhibitor_off", "y": 90 }
    },
    {
      "when": { "on": false, "facing": "south" },
      "apply": { "model": "mobsmash_ext_species_fix:block/soul_inhibitor_off", "y": 180 }
    },
    {
      "when": { "on": false, "facing": "west" },
      "apply": { "model": "mobsmash_ext_species_fix:block/soul_inhibitor_off", "y": 270 }
    }
  ]
}
